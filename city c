#include <iostream>
#include <string>
#include <chrono>

using namespace std;

// This is the core resident structure used in the main project
struct Resident {
    string residentID;
    int age;
    string modeOfTransport;
    float dailyDistance;
    float carbonEmissionFactor;
    float avgDayPerMonth;
    string ageGroup;
    float totalMonthlyEmission;
};

// ==========================================
// CITY C: LINKED LIST NODE STRUCTURE
// ==========================================
struct ResidentNode {
    Resident data;
    ResidentNode* next;
};

// ==========================================
// CITY C: LINKED LIST CLASS & OPERATIONS
// ==========================================
class CityCLinkedList {
public:
    ResidentNode* head;

    CityCLinkedList() {
        head = nullptr;
    }

    // 1. Insertion at the Beginning
    void insertAtBeginning(Resident resident) {
        ResidentNode* newNode = new ResidentNode();
        newNode->data = resident;
        newNode->next = head;
        head = newNode;
        cout << "Inserted resident " << resident.residentID << " at the beginning.\n";
    }

    // 2. Insertion at the End
    void insertAtEnd(Resident resident) {
        ResidentNode* newNode = new ResidentNode();
        newNode->data = resident;
        newNode->next = nullptr;

        if (head == nullptr) {
            head = newNode;
        } else {
            ResidentNode* temp = head;
            while (temp->next != nullptr) {
                temp = temp->next;
            }
            temp->next = newNode;
        }
        cout << "Inserted resident " << resident.residentID << " at the end.\n";
    }

    // 3. Insertion at a Specific Position
    void insertAtPosition(Resident resident, int position) {
        if (position <= 1) {
            insertAtBeginning(resident);
            return;
        }

        ResidentNode* newNode = new ResidentNode();
        newNode->data = resident;

        ResidentNode* temp = head;
        for (int i = 1; i < position - 1 && temp != nullptr; i++) {
            temp = temp->next;
        }

        if (temp == nullptr) {
            cout << "Position out of bounds. Inserting at the end.\n";
            insertAtEnd(resident);
        } else {
            newNode->next = temp->next;
            temp->next = newNode;
            cout << "Inserted resident " << resident.residentID << " at position " << position << ".\n";
        }
    }

    // 4. Deletion of a Node by Resident ID
    void deleteNode(string residentID) {
        if (head == nullptr) {
            cout << "List is empty.\n";
            return;
        }

        if (head->data.residentID == residentID) {
            ResidentNode* temp = head;
            head = head->next;
            delete temp;
            cout << "Deleted resident " << residentID << ".\n";
            return;
        }

        ResidentNode* temp = head;
        while (temp->next != nullptr && temp->next->data.residentID != residentID) {
            temp = temp->next;
        }

        if (temp->next == nullptr) {
            cout << "Resident ID " << residentID << " not found.\n";
        } else {
            ResidentNode* nodeToDelete = temp->next;
            temp->next = temp->next->next;
            delete nodeToDelete;
            cout << "Deleted resident " << residentID << ".\n";
        }
    }

    // 5. Searching for a Value by Resident ID
    void searchNode(string residentID) {
        ResidentNode* temp = head;
        int pos = 1;
        while (temp != nullptr) {
            if (temp->data.residentID == residentID) {
                cout << "Resident ID " << residentID << " found at position " << pos << ".\n";
                // Print a few details to show it works
                cout << " > Age: " << temp->data.age << " | Transport: " << temp->data.modeOfTransport << "\n";
                return;
            }
            temp = temp->next;
            pos++;
        }
        cout << "Resident ID " << residentID << " not found.\n";
    }

    // 6. Reversing the Linked List
    void reverseList() {
        ResidentNode* prev = nullptr;
        ResidentNode* current = head;
        ResidentNode* next = nullptr;

        while (current != nullptr) {
            next = current->next;
            current->next = prev;
            prev = current;
            current = next;
        }
        head = prev;
        cout << "Linked list reversed successfully.\n";
    }

    // Helper: Display entire list
    void displayList() {
        ResidentNode* temp = head;
        cout << "\n===== City C Linked List Data =====\n";
        int count = 0;
        while(temp != nullptr) {
            cout << temp->data.residentID << " | Age: " << temp->data.age << " | " << temp->data.totalMonthlyEmission << " Emission\n";
            temp = temp->next;
            count++;
        }
        cout << "Total Nodes: " << count << "\n===================================\n";
    }
};

// ==========================================
// CITY C: COMPARISON ANALYSIS
// ==========================================
// This function compares a generic array with our Linked List structure above
void compareArrayVsLinkedListCityC(Resident arrayData[], CityCLinkedList& listData, int residentCount) {
    cout << "\n===== Comparisation: Array vs Linked List (City C) =====\n";
    
    // --> 1. MEMORY USAGE COMPARISON
    size_t arrayMemory = residentCount * sizeof(Resident);
    
    int listSize = 0;
    ResidentNode* temp = listData.head;
    while(temp != nullptr) {
        listSize++;
        temp = temp->next;
    }
    size_t listMemory = listSize * sizeof(ResidentNode);
    
    cout << "--- Memory Usage ---\n";
    cout << "Array Memory (for " << residentCount << " residents) : " << arrayMemory << " bytes.\n";
    cout << "Linked List Memory (for " << listSize << " residents)   : " << listMemory << " bytes.\n";
    cout << "* Note: Linked List uses extra memory due to pointer overhead.\n\n";
    
    // --> 2. TRAVERSAL TIME COMPARISON
    cout << "--- Traversal Processing Time ---\n";
    
    // Array processing
    auto startArray = chrono::high_resolution_clock::now();
    float dummySumArr = 0;
    for(int i=0; i<residentCount; i++) {
        dummySumArr += arrayData[i].totalMonthlyEmission; 
    }
    auto endArray = chrono::high_resolution_clock::now();
    
    // Linked List processing
    auto startList = chrono::high_resolution_clock::now();
    float dummySumList = 0;
    temp = listData.head;
    while(temp != nullptr) {
        dummySumList += temp->data.totalMonthlyEmission;
        temp = temp->next;
    }
    auto endList = chrono::high_resolution_clock::now();
    
    cout << "Array Traversal Time       : " << chrono::duration_cast<chrono::nanoseconds>(endArray - startArray).count() << " ns\n";
    cout << "Linked List Traversal Time : " << chrono::duration_cast<chrono::nanoseconds>(endList - startList).count() << " ns\n";
}

