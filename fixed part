void age_group_analysis()
{
    Resident *data = getDataset(currentDataset);
    int size = citySizes[currentDataset];

    // Total emission and resident count for each age group
    float totalEmission[5] = {0};
    int count[5] = {0};

    // Modes of transport
    string modes[6] = {"Car", "Bus", "Bicycle", "Walking", "Carpool", "School Bus"};

    // Transportcount("Children", (e.g. "Car")5)
    int transportCount[5][6] = {0};

    for (int i = 0; i < size; i++)
    {
        int group;

        if (data[i].age <= 17)
            group = 0;
        else if (data[i].age <= 25)
            group = 1;
        else if (data[i].age <= 45)
            group = 2;
        else if (data[i].age <= 60)
            group = 3;
        else
            group = 4;

        totalEmission[group] += data[i].totalMonthlyEmission;
        count[group]++;

        for (int j = 0; j < 6; j++)
        {
            if (data[i].modeOfTransport == modes[j])
            {
                transportCount[group][j]++;
                break;
            }
        }
    }
    string groups[5] = {"6 - 17 (Children & Teenagers)", "18 - 25 (University Students / Young Adults)", "26 - 45 (Working Adults (Early Career))", "46 - 60 (Working Adults (Late Career)", "61+ (Senior Citizens / Retirees)"};

    cout << "=====Age Group Analysis===== \n";
    cout << left << setw(50) << "Age Group"
         << setw(30) << "Preferred Mode Of Transport"
         << setw(20) << "Total Emission"
         << setw(20) << "Average Emission" << "\n";

    for (int i = 0; i < 5; i++)
    {
        float avg = (count[i] == 0) ? 0 : totalEmission[i] / count[i];
        string preferred = "N/A";
        int max = 0;

        for (int j = 0; j < 6; j++)
        {
            if (transportCount[i][j] > max)
            {
                max = transportCount[i][j];
                preferred = modes[j];
            }
        }
        cout << left << setw(50) << groups[i]
             << setw(30) << preferred
             << setw(20) << totalEmission[i]
             << setw(20) << avg << "\n";
    }
}
