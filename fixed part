/*==========SORTING ALGORITHMS==========*/
void bubblesort(int dataset, string field)
{
    Resident *data = getDataset(dataset);
    int size = citySizes[dataset];

    // Record time and memory usuage
    auto start = chrono::high_resolution_clock::now();
    size_t memoryUsed = calculateMemoryUsage(dataset);

    // Tempory swap memory
    memoryUsed += sizeof(Resident);

    for (int i = 0; i < size - 1; i++)
    {
        for (int j = 0; j < size - i - 1; j++)
        {
            bool swap = false;
            if (field == "age" && data[j].age > data[j + 1].age)
                swap = true;
            else if (field == "dailyDistance" && data[j].dailyDistance > data[j + 1].dailyDistance)
                swap = true;
            else if (field == "carbonEmissionFactor" && data[j].totalMonthlyEmission > data[j + 1].totalMonthlyEmission)
                swap = true;

            if (swap)
            {
                Resident temp = data[j];
                data[j] = data[j + 1];
                data[j + 1] = temp;
            }
        }
    }
    auto end = chrono::high_resolution_clock::now();
    auto duration = chrono::duration_cast<chrono::microseconds>(end - start);
    display_all_residents();
    cout << "Time Taken: " << duration.count() << " microseconds\n";
    cout << "Memory Used: " << memoryUsed << " bytes\n";
    ;
}

void insertionsort(int dataset, string field)
{
    Resident *data = getDataset(dataset);
    int size = citySizes[dataset];

    auto start = chrono::high_resolution_clock::now();
    size_t memoryUsed = calculateMemoryUsage(dataset);

    // key memory
    memoryUsed += sizeof(Resident);

    for (int i = 1; i < size; i++)
    {
        Resident key = data[i];
        int j = i - 1;

        while (j >= 0)
        {
            bool condition = false;

            if (field == "age" && data[j].age > key.age)
                condition = true;

            else if (field == "dailyDistance" && data[j].dailyDistance > key.dailyDistance)
                condition = true;

            else if (field == "carbonEmissionFactor" && data[j].totalMonthlyEmission > key.totalMonthlyEmission)
                condition = true;

            if (!condition)
                break;

            data[j + 1] = data[j];
            j--;
        }
        data[j + 1] = key;
    }
    auto end = chrono::high_resolution_clock::now();
    auto duration = chrono::duration_cast<chrono::microseconds>(end - start);
    display_all_residents();
    cout << "Time Taken: " << duration.count() << " microseconds\n";
    cout << "Memory Used: " << memoryUsed << " bytes\n";
}

