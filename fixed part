void insert_resident()
{
    Resident* data = getDataset(currentDataset);
    int& size = citySizes[currentDataset];

    if (size >= max_residents) {
        cout << "Dataset is full. Cannot insert more residents.\n";
        return;
    }

    Resident temp;
    cout << "Enter Resident ID: ";
    cin >> temp.residentID;
    cout << "Enter Age: ";
    cin >> temp.age;
    cout << "Enter Mode of Transport: ";
    cin >> temp.modeOfTransport;
    cout << "Enter Daily Distance: ";
    cin >> temp.dailyDistance;
    cout << "Enter Carbon Emission Factor: ";
    cin >> temp.carbonEmissionFactor;
    cout << "Enter Average Days Per Month: ";
    cin >> temp.avgDayPerMonth;

    if (temp.age >= 6 && temp.age <= 17)
        temp.ageGroup = "Children & Teenagers";
    else if (temp.age >= 18 && temp.age <= 25)
        temp.ageGroup = "University Students / Young Adults";
    else if (temp.age >= 26 && temp.age <= 45)
        temp.ageGroup = "Working Adults (Early Career)";
    else if (temp.age >= 46 && temp.age <= 60)
        temp.ageGroup = "Working Adults (Late Career)";
    else if (temp.age >= 61)
        temp.ageGroup = "Senior Citizens / Retirees";
    else
        temp.ageGroup = "Other";

    temp.totalMonthlyEmission = temp.dailyDistance * temp.carbonEmissionFactor * temp.avgDayPerMonth;

    // Insertion Algorithm into Array
    data[size] = temp;
    
    // If it's City C, insert to linked list as well
    if (currentDataset == 2) {
        cityCLinkedList.insertAtEnd(temp, true);
    }
    
    size++;
    cout << "Resident successfully inserted into " << datasetNames[currentDataset] << "!\n";
}

void initialise_datasets()
{
    string inputFiles[3] = {"datasetA.csv", "datasetB.csv", "datasetC.csv"};
    Resident *targetCities[3] = {cityA, cityB, cityC};

    for (int i = 0; i < 3; i++)
    {
        ifstream datasetFile(inputFiles[i]);
        if (!datasetFile.is_open())
        {
            datasetFile.open("C Assignment/" + inputFiles[i]);
        }
        if (!datasetFile.is_open())
        {
            datasetFile.open("../C Assignment/" + inputFiles[i]);
        }
        
        if (!datasetFile.is_open())
        {
            cout << "Error: Could not open file " << inputFiles[i] << " (Check if you're in the right directory)\n";
            continue;
        }

        string line;
        getline(datasetFile, line); // Skip header

        int index = 0;
        while (getline(datasetFile, line) && index < max_residents)
        {
            if (line.empty())
                continue;

            stringstream ss(line);
            string token;
            Resident temp;

            getline(ss, temp.residentID, ',');
            getline(ss, token, ','); temp.age = stoi(token);
            getline(ss, temp.modeOfTransport, ',');
            getline(ss, token, ','); temp.dailyDistance = stof(token);
            getline(ss, token, ','); temp.carbonEmissionFactor = stof(token);
            getline(ss, token, ','); temp.avgDayPerMonth = stof(token);
            getline(ss, temp.ageGroup, ',');
            getline(ss, token, ','); temp.totalMonthlyEmission = stof(token);

            targetCities[i][index] = temp;
            
            // Populate City C linked list too for comparison
            if (i == 2) {
                if (index == 0) cityCLinkedList.clearList(); // Ensure it's empty first
                cityCLinkedList.insertAtEnd(temp, true); // true for quiet mode
            }
            index++;
        }
        citySizes[i] = index;
        cout << "Loaded: " << inputFiles[i] << " with " << index << " records\n";

        datasetFile.close();
    }
}

