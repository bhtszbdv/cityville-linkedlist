void linearsearch(int dataset, string field) {
    Resident* data=getDataset(dataset); int size=citySizes[dataset];
    auto start=chrono::high_resolution_clock::now();
    int found=0;
    if(field=="age"){ int v; cout<<"Enter age: "; cin>>v;
        for(int i=0;i<size;i++) if(data[i].age==v){cout<<data[i].residentID<<" age="<<data[i].age<<" em="<<data[i].totalMonthlyEmission<<"\n";found++;}
    } else if(field=="modeOfTransport"){ string v; cout<<"Enter transport: "; cin>>v;
        for(int i=0;i<size;i++) if(data[i].modeOfTransport==v){cout<<data[i].residentID<<" transport="<<data[i].modeOfTransport<<"\n";found++;}
    } else if(field=="dailyDistance"){ float v; cout<<"Enter distance: "; cin>>v;
        for(int i=0;i<size;i++) if(data[i].dailyDistance==v){cout<<data[i].residentID<<" dist="<<data[i].dailyDistance<<"\n";found++;}
    }
    auto end=chrono::high_resolution_clock::now();
    cout<<"Found "<<found<<" results in "<<chrono::duration_cast<chrono::microseconds>(end-start).count()<<" us\n";
}

void binarysearch(int dataset, string field) {
    Resident* data=getDataset(dataset); int size=citySizes[dataset];
    // Sort first
    if(field=="age") { for(int i=0;i<size-1;i++) for(int j=0;j<size-i-1;j++) if(data[j].age>data[j+1].age){Resident t=data[j];data[j]=data[j+1];data[j+1]=t;} }
    else if(field=="dailyDistance") { for(int i=0;i<size-1;i++) for(int j=0;j<size-i-1;j++) if(data[j].dailyDistance>data[j+1].dailyDistance){Resident t=data[j];data[j]=data[j+1];data[j+1]=t;} }
    
    auto start=chrono::high_resolution_clock::now();
    if(field=="age"){ int v; cout<<"Enter age: "; cin>>v;
        int lo=0,hi=size-1,found=-1;
        while(lo<=hi){int m=(lo+hi)/2; if(data[m].age==v){found=m;break;} else if(data[m].age<v) lo=m+1; else hi=m-1;}
        if(found>=0) cout<<"Found: "<<data[found].residentID<<" age="<<data[found].age<<"\n"; else cout<<"Not found.\n";
    } else if(field=="dailyDistance"){ float v; cout<<"Enter distance: "; cin>>v;
        int lo=0,hi=size-1,found=-1;
        while(lo<=hi){int m=(lo+hi)/2; if(data[m].dailyDistance==v){found=m;break;} else if(data[m].dailyDistance<v) lo=m+1; else hi=m-1;}
        if(found>=0) cout<<"Found: "<<data[found].residentID<<" dist="<<data[found].dailyDistance<<"\n"; else cout<<"Not found.\n";
    } else { cout<<"Binary search on strings not supported. Use linear search.\n"; }
    auto end=chrono::high_resolution_clock::now();
    cout<<"Binary search took "<<chrono::duration_cast<chrono::microseconds>(end-start).count()<<" us\n";
}

