void age_group_analysis() {
    Resident* data=getDataset(currentDataset); int size=citySizes[currentDataset];
    float totalE[5]={0}; int count[5]={0};
    string modes[6]={"Car","Bus","Bicycle","Walking","Carpool","School Bus"};
    int tc[5][6]={};
    for(int i=0;i<size;i++){
        int g; if(data[i].age<=17) g=0; else if(data[i].age<=25) g=1; else if(data[i].age<=45) g=2; else if(data[i].age<=60) g=3; else g=4;
        totalE[g]+=data[i].totalMonthlyEmission; count[g]++;
        for(int j=0;j<6;j++) if(data[i].modeOfTransport==modes[j]){tc[g][j]++;break;}
    }
    string groups[5]={"6-17 (Children)","18-25 (Young Adults)","26-45 (Early Career)","46-60 (Late Career)","61+ (Seniors)"};
    cout<<"=====Age Group Analysis=====\n";
    cout<<left<<setw(30)<<"Age Group"<<setw(20)<<"Pref Transport"<<setw(15)<<"Total Em"<<setw(15)<<"Avg Em"<<"\n";
    for(int i=0;i<5;i++){
        float avg=(count[i]==0)?0:totalE[i]/count[i]; string pref="N/A"; int mx=0;
        for(int j=0;j<6;j++) if(tc[i][j]>mx){mx=tc[i][j];pref=modes[j];}
        cout<<left<<setw(30)<<groups[i]<<setw(20)<<pref<<setw(15)<<totalE[i]<<setw(15)<<avg<<"\n";
    }
}

