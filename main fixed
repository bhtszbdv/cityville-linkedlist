string trim(const string& s) {
    size_t start=s.find_first_not_of(" \t\r\n");
    if(start==string::npos) return "";
    return s.substr(start, s.find_last_not_of(" \t\r\n")-start+1);
}

void initialise_datasets() {
    string inputFiles[3]={"datasetA.csv","datasetB.csv","datasetC.csv"};
    Resident* targets[3]={cityA,cityB,cityC};
    string searchPaths[] = {"", "C:\\Users\\User\\Downloads\\", "C Assignment/", "../C Assignment/"};

    for(int i=0;i<3;i++){
        ifstream f;
        for(auto& p : searchPaths) {
            f.open(p + inputFiles[i]);
            if(f.is_open()) break;
        }
        if(!f.is_open()){cout<<"Error: "<<inputFiles[i]<<" not found.\n";continue;}
        string line; getline(f,line); int idx=0;
        while(getline(f,line)&&idx<max_residents){
            if(line.empty()) continue;
            // Remove trailing \r if present
            if(!line.empty() && line.back()=='\r') line.pop_back();
            stringstream ss(line); string tok; Resident t;
            getline(ss,t.residentID,',');
            getline(ss,tok,','); t.age=stoi(trim(tok));
            getline(ss,t.modeOfTransport,','); t.modeOfTransport=trim(t.modeOfTransport);
            getline(ss,tok,','); t.dailyDistance=stof(trim(tok));
            getline(ss,tok,','); t.carbonEmissionFactor=stof(trim(tok));
            getline(ss,tok,','); t.avgDayPerMonth=stof(trim(tok));
            getline(ss,t.ageGroup,','); t.ageGroup=trim(t.ageGroup);
            getline(ss,tok,','); t.totalMonthlyEmission=stof(trim(tok));
            targets[i][idx]=t;
            if(i==2){if(idx==0) cityCLinkedList.clearList(); cityCLinkedList.insertAtEnd(t,true);}
            idx++;
        }
        citySizes[i]=idx;
        cout<<"Loaded "<<inputFiles[i]<<": "<<idx<<" records\n";
        f.close();
    }
}

