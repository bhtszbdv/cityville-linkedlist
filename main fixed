void bubblesort(int dataset, string field) {
    Resident* data=getDataset(dataset); int size=citySizes[dataset];
    auto start=chrono::high_resolution_clock::now();
    size_t mem=calculateMemoryUsage(dataset)+sizeof(Resident);
    for(int i=0;i<size-1;i++)
        for(int j=0;j<size-i-1;j++){
            bool sw=false;
            if(field=="age"&&data[j].age>data[j+1].age) sw=true;
            else if(field=="dailyDistance"&&data[j].dailyDistance>data[j+1].dailyDistance) sw=true;
            else if(field=="carbonEmissionFactor"&&data[j].totalMonthlyEmission>data[j+1].totalMonthlyEmission) sw=true;
            if(sw){Resident t=data[j];data[j]=data[j+1];data[j+1]=t;}
        }
    auto end=chrono::high_resolution_clock::now();
    display_all_residents();
    cout<<"Array Bubble Sort: "<<chrono::duration_cast<chrono::microseconds>(end-start).count()<<" us | Memory: "<<mem<<" bytes\n";
}

void insertionsort(int dataset, string field) {
    Resident* data=getDataset(dataset); int size=citySizes[dataset];
    auto start=chrono::high_resolution_clock::now();
    size_t mem=calculateMemoryUsage(dataset)+sizeof(Resident);
    for(int i=1;i<size;i++){
        Resident key=data[i]; int j=i-1;
        while(j>=0){
            bool c=false;
            if(field=="age"&&data[j].age>key.age) c=true;
            else if(field=="dailyDistance"&&data[j].dailyDistance>key.dailyDistance) c=true;
            else if(field=="carbonEmissionFactor"&&data[j].totalMonthlyEmission>key.totalMonthlyEmission) c=true;
            if(!c) break;
            data[j+1]=data[j]; j--;
        }
        data[j+1]=key;
    }
    auto end=chrono::high_resolution_clock::now();
    display_all_residents();
    cout<<"Array Insertion Sort: "<<chrono::duration_cast<chrono::microseconds>(end-start).count()<<" us | Memory: "<<mem<<" bytes\n";
}

