    cout<<"--- Memory ---\nArray: "<<arrMem<<" bytes ("<<sz<<" residents)\nLinked List: "<<lstMem<<" bytes ("<<lsz<<" residents)\n\n";
    cout<<"--- Traversal ---\n";
    auto s1=chrono::high_resolution_clock::now(); float d1=0; for(int i=0;i<sz;i++) d1+=cityC[i].totalMonthlyEmission;
