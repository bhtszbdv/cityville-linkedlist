struct Resident {
    string residentID;
    int age;
    string modeOfTransport;
    float dailyDistance;
    float carbonEmissionFactor;
    float avgDayPerMonth;
    string ageGroup;
    float totalMonthlyEmission;
};

struct ResidentNode {
    Resident data;
    ResidentNode* next;
};

class CityCLinkedList {
public:
    ResidentNode* head;
    CityCLinkedList() { head = nullptr; }

    void insertAtBeginning(Resident resident) {
        ResidentNode* n = new ResidentNode(); n->data = resident; n->next = head; head = n;
        cout << "Inserted " << resident.residentID << " at beginning.\n";
    }
    void insertAtEnd(Resident resident, bool quiet=false) {
        ResidentNode* n = new ResidentNode(); n->data = resident; n->next = nullptr;
        if (!head) { head = n; } else { ResidentNode* t = head; while(t->next) t=t->next; t->next = n; }
        if(!quiet) cout << "Inserted " << resident.residentID << " at end.\n";
    }
    void insertAtPosition(Resident resident, int pos) {
        if (pos <= 1) { insertAtBeginning(resident); return; }
        ResidentNode* n = new ResidentNode(); n->data = resident;
        ResidentNode* t = head;
        for (int i=1; i<pos-1 && t; i++) t=t->next;
        if (!t) { insertAtEnd(resident); } else { n->next=t->next; t->next=n; cout<<"Inserted "<<resident.residentID<<" at pos "<<pos<<".\n"; }
    }
    void deleteNode(string id) {
        if (!head) { cout<<"List empty.\n"; return; }
        if (head->data.residentID==id) { ResidentNode* t=head; head=head->next; delete t; cout<<"Deleted "<<id<<".\n"; return; }
        ResidentNode* t=head;
        while(t->next && t->next->data.residentID!=id) t=t->next;
        if (!t->next) cout<<id<<" not found.\n";
        else { ResidentNode* d=t->next; t->next=d->next; delete d; cout<<"Deleted "<<id<<".\n"; }
    }
    void searchNode(string id) {
        ResidentNode* t=head; int p=1;
        while(t) { if(t->data.residentID==id){cout<<id<<" found at pos "<<p<<".\n";return;} t=t->next;p++; }
        cout<<id<<" not found.\n";
    }
    void reverseList() {
        ResidentNode *prev=nullptr,*cur=head,*nxt=nullptr;
        while(cur){nxt=cur->next;cur->next=prev;prev=cur;cur=nxt;} head=prev;
        cout<<"List reversed.\n";
    }
    void displayList() {
        ResidentNode* t=head; int c=0;
        cout<<"=====City C Linked List=====\n";
        cout<<left<<setw(10)<<"ID"<<setw(6)<<"Age"<<setw(15)<<"Transport"<<setw(10)<<"Dist"<<setw(10)<<"CF"<<setw(8)<<"Days"<<setw(30)<<"AgeGroup"<<setw(10)<<"Emission"<<"\n";
        while(t){
            cout<<left<<setw(10)<<t->data.residentID<<setw(6)<<t->data.age<<setw(15)<<t->data.modeOfTransport
                <<setw(10)<<t->data.dailyDistance<<setw(10)<<t->data.carbonEmissionFactor<<setw(8)<<t->data.avgDayPerMonth
                <<setw(30)<<t->data.ageGroup<<setw(10)<<t->data.totalMonthlyEmission<<"\n";
            t=t->next; c++;
        }
        cout<<"Total: "<<c<<" records\n";
    }
    void clearList() { while(head){ResidentNode* n=head->next;delete head;head=n;} }

    // Bubble Sort for linked list
    void bubbleSortList(string field) {
        if (!head) return;
        auto start = chrono::high_resolution_clock::now();
        bool swapped; 
        do {
            swapped = false;
            ResidentNode* cur = head;
            while (cur->next) {
                bool doSwap = false;
                if (field=="age" && cur->data.age > cur->next->data.age) doSwap=true;
                else if (field=="dailyDistance" && cur->data.dailyDistance > cur->next->data.dailyDistance) doSwap=true;
                else if (field=="carbonEmissionFactor" && cur->data.totalMonthlyEmission > cur->next->data.totalMonthlyEmission) doSwap=true;
                if (doSwap) { Resident tmp=cur->data; cur->data=cur->next->data; cur->next->data=tmp; swapped=true; }
                cur = cur->next;
            }
        } while (swapped);
        auto end = chrono::high_resolution_clock::now();
        cout<<"Linked List Bubble Sort done in "<<chrono::duration_cast<chrono::microseconds>(end-start).count()<<" us\n";
        displayList();
    }

    // Insertion Sort for linked list
    void insertionSortList(string field) {
        if (!head || !head->next) return;
        auto start = chrono::high_resolution_clock::now();
        ResidentNode* sorted = nullptr;
        ResidentNode* cur = head;
        while (cur) {
            ResidentNode* nxt = cur->next;
            // Find insertion point in sorted list
            if (!sorted || compareNodes(cur, sorted, field)) {
                cur->next = sorted; sorted = cur;
            } else {
                ResidentNode* t = sorted;
                while (t->next && !compareNodes(cur, t->next, field)) t = t->next;
                cur->next = t->next; t->next = cur;
            }
            cur = nxt;
        }
        head = sorted;
        auto end = chrono::high_resolution_clock::now();
        cout<<"Linked List Insertion Sort done in "<<chrono::duration_cast<chrono::microseconds>(end-start).count()<<" us\n";
        displayList();
    }

    bool compareNodes(ResidentNode* a, ResidentNode* b, string field) {
        if (field=="age") return a->data.age < b->data.age;
        if (field=="dailyDistance") return a->data.dailyDistance < b->data.dailyDistance;
        return a->data.totalMonthlyEmission < b->data.totalMonthlyEmission;
    }
};

