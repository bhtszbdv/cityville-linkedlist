    void binarySearchByAge(int target) const{
        cout<<"\n  [Binary Search] Age = "<<target<<"\n";
        auto s=chrono::high_resolution_clock::now();
        Node**arr=new Node*[count];Node*c=head;for(int i=0;i<count;i++,c=c->next)arr[i]=c;
        int lo=0,hi=count-1,f=0;
        while(lo<=hi){int m=(lo+hi)/2;if(arr[m]->age==target){int L=m,R=m;while(L>0&&arr[L-1]->age==target)L--;while(R<count-1&&arr[R+1]->age==target)R++;
            cout<<"  "<<left<<setw(8)<<"ID"<<setw(6)<<"Age"<<setw(14)<<"Mode"<<setw(10)<<"Dist"<<setw(14)<<"Emission"<<"\n  "<<string(52,'-')<<"\n";
            for(int i=L;i<=R;i++){cout<<"  "<<left<<setw(8)<<arr[i]->residentID<<setw(6)<<arr[i]->age<<setw(14)<<arr[i]->mode<<setw(10)<<fixed<<setprecision(1)<<arr[i]->distance<<setw(14)<<fixed<<setprecision(2)<<arr[i]->totalEmission<<"\n";f++;}break;}
            else if(arr[m]->age<target)lo=m+1;else hi=m-1;}
        delete[]arr;
        double ms=chrono::duration<double,milli>(chrono::high_resolution_clock::now()-s).count();
        if(f==0)cout<<"  Not found.\n";
        cout<<"  Found "<<f<<" | Time: "<<fixed<<setprecision(4)<<ms<<" ms\n  Complexity: O(log n) | Space: O(n)\n";
    }

    // ---- ANALYSIS ----
    void carbonAnalysis() const{
        if(!head){cout<<"  (no data)\n";return;}
        map<string,double>me;map<string,int>mc;double tot=0;
        Node*c=head;while(c){me[c->mode]+=c->totalEmission;mc[c->mode]++;tot+=c->totalEmission;c=c->next;}
        cout<<"\n  ========== CARBON EMISSION ANALYSIS ==========\n  Total: "<<count<<" residents | "<<fixed<<setprecision(2)<<tot<<" kg CO2/month | Avg: "<<tot/count<<"\n";
        cout<<"  "<<left<<setw(16)<<"Mode"<<setw(8)<<"Count"<<setw(14)<<"Total"<<setw(14)<<"Avg"<<setw(8)<<"Share%"<<"\n  "<<string(60,'-')<<"\n";
        for(auto&[m,e]:me){int n=mc[m];cout<<"  "<<left<<setw(16)<<m<<setw(8)<<n<<setw(14)<<fixed<<setprecision(2)<<e<<setw(14)<<e/n<<setw(8)<<setprecision(1)<<(tot>0?e/tot*100:0)<<"\n";}
        cout<<"  "<<string(60,'-')<<"\n";
    }
    void ageGroupAnalysis() const{
        if(!head){cout<<"  (no data)\n";return;}
        const string G[]={"Children & Teenagers","University Students / Young Adults","Working Adults (Early Career)","Working Adults (Late Career)","Senior Citizens / Retirees"};
        map<string,double>ge;map<string,int>gc;map<string,map<string,int>>gm;
        Node*c=head;while(c){string g=ageGroupLabel(c->age);ge[g]+=c->totalEmission;gc[g]++;gm[g][c->mode]++;c=c->next;}
        cout<<"\n  ========== AGE GROUP ANALYSIS ==========\n";
        cout<<"  "<<left<<setw(38)<<"Group"<<setw(8)<<"Count"<<setw(14)<<"Total"<<setw(14)<<"Avg"<<setw(14)<<"Pref Mode"<<"\n  "<<string(88,'-')<<"\n";
        for(auto&g:G){if(gc.find(g)==gc.end())continue;int n=gc[g];double e=ge[g];string pm="-";int mx=0;
            for(auto&[m,ct]:gm[g])if(ct>mx){mx=ct;pm=m;}
            cout<<"  "<<left<<setw(38)<<g<<setw(8)<<n<<setw(14)<<fixed<<setprecision(2)<<e<<setw(14)<<e/n<<setw(14)<<pm<<"\n";}
        cout<<"  "<<string(88,'-')<<"\n";
    }

