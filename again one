    void linearSearchByDistanceThreshold(double mn) const{
        cout<<"\n  [Linear Search] Distance > "<<mn<<" km\n";
        auto s=chrono::high_resolution_clock::now();int f=0;Node*c=head;
        cout<<"  "<<left<<setw(8)<<"ID"<<setw(6)<<"Age"<<setw(14)<<"Mode"<<setw(10)<<"Dist"<<setw(14)<<"Emission"<<"\n  "<<string(52,'-')<<"\n";
        while(c){if(c->distance>mn){cout<<"  "<<left<<setw(8)<<c->residentID<<setw(6)<<c->age<<setw(14)<<c->mode<<setw(10)<<fixed<<setprecision(1)<<c->distance<<setw(14)<<fixed<<setprecision(2)<<c->totalEmission<<"\n";f++;}c=c->next;}
        double ms=chrono::duration<double,milli>(chrono::high_resolution_clock::now()-s).count();
        cout<<"  "<<string(52,'-')<<"\n  Found "<<f<<" | Time: "<<fixed<<setprecision(4)<<ms<<" ms\n  Complexity: O(n) | Space: O(1)\n";
