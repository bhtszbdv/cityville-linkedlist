    void totalEmissionsReport(char) const{carbonAnalysis();}
    void emissionsByMode(char) const{carbonAnalysis();}
    void transportPercentageDistribution(char) const{
        if(!head)return;map<string,int>mc;Node*c=head;while(c){mc[c->mode]++;c=c->next;}
        cout<<"\n  ========== TRANSPORT DISTRIBUTION ==========\n";
        for(auto&[m,n]:mc)cout<<"  "<<left<<setw(16)<<m<<": "<<fixed<<setprecision(1)<<(double)n/count*100<<"%\n";
    }
    void ageGroupAnalysisExtended(char) const{ageGroupAnalysis();}
    void topBottomEmitters(int n) const{
        if(!head||n<=0)return;
        vector<Node*>v;Node*c=head;while(c){v.push_back(c);c=c->next;}
        for(int i=0;i<(int)v.size()-1;i++)for(int j=0;j<(int)v.size()-i-1;j++)if(v[j]->totalEmission>v[j+1]->totalEmission)swap(v[j],v[j+1]);
        cout<<"\n  Top "<<n<<" emitters:\n";for(int i=(int)v.size()-1;i>=max(0,(int)v.size()-n);i--)cout<<"  "<<v[i]->residentID<<" "<<fixed<<setprecision(2)<<v[i]->totalEmission<<"\n";
        cout<<"  Bottom "<<n<<" emitters:\n";for(int i=0;i<min(n,(int)v.size());i++)cout<<"  "<<v[i]->residentID<<" "<<fixed<<setprecision(2)<<v[i]->totalEmission<<"\n";
    }
