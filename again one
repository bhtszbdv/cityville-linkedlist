        cout<<"\n  [Multi Search] Dist>"<<mn<<" AND Mode=\""<<mode<<"\"\n";int f=0;Node*c=head;
        while(c){string a=c->mode,b=mode;for(char&x:a)x=tolower(x);for(char&x:b)x=tolower(x);
            if(c->distance>mn&&a==b){cout<<"  "<<c->residentID<<" dist="<<fixed<<setprecision(1)<<c->distance<<" "<<c->mode<<" em="<<setprecision(2)<<c->totalEmission<<"\n";f++;}c=c->next;}
        cout<<"  Found "<<f<<"\n";
