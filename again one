        cout<<"\n  [Multi Search] Age "<<mn<<"-"<<mx<<" AND Mode=\""<<mode<<"\"\n";int f=0;Node*c=head;
        while(c){string a=c->mode,b=mode;for(char&x:a)x=tolower(x);for(char&x:b)x=tolower(x);
            if(c->age>=mn&&c->age<=mx&&a==b){cout<<"  "<<c->residentID<<" age="<<c->age<<" "<<c->mode<<" em="<<fixed<<setprecision(2)<<c->totalEmission<<"\n";f++;}c=c->next;}
        cout<<"  Found "<<f<<"\n";
    }
