using namespace std;

struct Node {
    string residentID; int age; string mode;
    double distance, emissionFactor; int days;
    string ageGroup; double totalEmission;
    Node* next;
    Node():age(0),distance(0),emissionFactor(0),days(0),totalEmission(0),next(nullptr){}
};

class LinkedList {
    Node* head; int count; double lastSortTimeMs;
    static void swapData(Node*a,Node*b){
        swap(a->residentID,b->residentID);swap(a->age,b->age);swap(a->mode,b->mode);
        swap(a->distance,b->distance);swap(a->emissionFactor,b->emissionFactor);
        swap(a->days,b->days);swap(a->ageGroup,b->ageGroup);swap(a->totalEmission,b->totalEmission);
    }
public:
    LinkedList():head(nullptr),count(0),lastSortTimeMs(0){}
    ~LinkedList(){clear();}
    int size() const{return count;}
    double sortTime() const{return lastSortTimeMs;}

    static string ageGroupLabel(int age, char prefix='X'){
        if(age>=6&&age<=17) return "Children & Teenagers";
        if(age>=18&&age<=25) return "University Students / Young Adults";
        if(age>=26&&age<=45) return "Working Adults (Early Career)";
        if(age>=46&&age<=60) return "Working Adults (Late Career)";
        if(age>=61) return "Senior Citizens / Retirees";
        return "Unknown";
    }

    void clear(){Node*c=head;while(c){Node*n=c->next;delete c;c=n;}head=nullptr;count=0;}

    void insert(const string&id,int age,const string&mode,double dist,double em,int days,const string&ag="",double te=-1){
        Node*n=new Node();n->residentID=id;n->age=age;n->mode=mode;n->distance=dist;
        n->emissionFactor=em;n->days=days;
        n->ageGroup=ag.empty()?ageGroupLabel(age):ag;
        n->totalEmission=(te<0)?dist*em*days:te;
        n->next=nullptr;
        if(!head){head=n;}else{Node*c=head;while(c->next)c=c->next;c->next=n;}
        count++;
    }

    void insertAtBeginning(const string&id,int age,const string&mode,double dist,double em,int days,const string&ag="",double te=-1){
        Node*n=new Node();n->residentID=id;n->age=age;n->mode=mode;n->distance=dist;
        n->emissionFactor=em;n->days=days;
        n->ageGroup=ag.empty()?ageGroupLabel(age):ag;
        n->totalEmission=(te<0)?dist*em*days:te;
        n->next=head;head=n;count++;
        cout<<"  Inserted "<<id<<" at beginning (position 1).\n";
    }

    void insertAtPosition(int pos,const string&id,int age,const string&mode,double dist,double em,int days,const string&ag="",double te=-1){
        if(pos<=1){insertAtBeginning(id,age,mode,dist,em,days,ag,te);return;}
        Node*n=new Node();n->residentID=id;n->age=age;n->mode=mode;n->distance=dist;
        n->emissionFactor=em;n->days=days;
        n->ageGroup=ag.empty()?ageGroupLabel(age):ag;
        n->totalEmission=(te<0)?dist*em*days:te;
        Node*t=head;for(int i=1;i<pos-1&&t;i++)t=t->next;
        if(!t){n->next=nullptr;Node*c=head;while(c->next)c=c->next;c->next=n;}
        else{n->next=t->next;t->next=n;}
        count++;
        cout<<"  Inserted "<<id<<" at position "<<pos<<".\n";
    }

    bool deleteResident(const string&id){
        if(!head){cout<<"  List empty.\n";return false;}
        if(head->residentID==id){Node*t=head;head=head->next;delete t;count--;cout<<"  Deleted "<<id<<".\n";return true;}
        Node*t=head;while(t->next&&t->next->residentID!=id)t=t->next;
        if(!t->next){cout<<"  "<<id<<" not found.\n";return false;}
        Node*d=t->next;t->next=d->next;delete d;count--;cout<<"  Deleted "<<id<<".\n";return true;
    }

    void reverse(){
        Node*prev=nullptr,*cur=head,*nxt;
        while(cur){nxt=cur->next;cur->next=prev;prev=cur;cur=nxt;}
        head=prev;cout<<"  List reversed.\n";
    }

    bool loadFromCSV(const string&fn){
        ifstream f(fn);if(!f.is_open()){cout<<"  [ERROR] Cannot open "<<fn<<"\n";return false;}
        string line;getline(f,line);int loaded=0;
        auto trim=[](string&s){size_t a=s.find_first_not_of(" \t\r\n");size_t b=s.find_last_not_of(" \t\r\n");s=(a==string::npos)?"":s.substr(a,b-a+1);};
        while(getline(f,line)){
            if(line.empty()||line=="\r")continue;
            if(!line.empty()&&line.back()=='\r')line.pop_back();
            stringstream ss(line);
            string id,ageS,mode,distS,emS,daysS,ag,totS;
            getline(ss,id,',');getline(ss,ageS,',');getline(ss,mode,',');getline(ss,distS,',');
            getline(ss,emS,',');getline(ss,daysS,',');getline(ss,ag,',');getline(ss,totS,',');
            trim(id);trim(ageS);trim(mode);trim(distS);trim(emS);trim(daysS);trim(ag);trim(totS);
            if(id.empty())continue;
            try{
                int age=stoi(ageS);double dist=stod(distS);double em=stod(emS);int days=stoi(daysS);
                double tot=totS.empty()?dist*em*days:stod(totS);
                insert(id,age,mode,dist,em,days,ag,tot);loaded++;
            }catch(...){}
        }
        f.close();cout<<"  Loaded "<<loaded<<" records from "<<fn<<"\n";return true;
    }

    void saveToCSV() const{}

    void display() const{
        if(!head){cout<<"  (no data)\n";return;}
        cout<<"\n"<<left<<setw(8)<<"ID"<<setw(6)<<"Age"<<setw(36)<<"Age Group"<<setw(14)<<"Mode"
            <<setw(10)<<"Dist(km)"<<setw(14)<<"TotalEmis(kg)"<<"\n"<<string(88,'-')<<"\n";
        Node*c=head;while(c){
            cout<<left<<setw(8)<<c->residentID<<setw(6)<<c->age<<setw(36)<<c->ageGroup
                <<setw(14)<<c->mode<<setw(10)<<fixed<<setprecision(1)<<c->distance
                <<setw(14)<<fixed<<setprecision(2)<<c->totalEmission<<"\n";
            c=c->next;
        }
        cout<<string(88,'-')<<"\n  Total records: "<<count<<"\n";
    }

    // ---- BUBBLE SORT ----
    void sortByAge(){
        if(!head||!head->next)return;
        auto s=chrono::high_resolution_clock::now();bool sw;
        do{sw=false;Node*c=head;while(c->next){if(c->age>c->next->age){swapData(c,c->next);sw=true;}c=c->next;}}while(sw);
        lastSortTimeMs=chrono::duration<double,milli>(chrono::high_resolution_clock::now()-s).count();
        cout<<"\n  [Bubble Sort by Age] "<<count<<" nodes in "<<fixed<<setprecision(4)<<lastSortTimeMs<<" ms\n";
        cout<<"  Time Complexity: O(n^2) | Space: O(1)\n";
    }
    void sortByDistance(){
        if(!head||!head->next)return;
        auto s=chrono::high_resolution_clock::now();bool sw;
        do{sw=false;Node*c=head;while(c->next){if(c->distance>c->next->distance){swapData(c,c->next);sw=true;}c=c->next;}}while(sw);
        lastSortTimeMs=chrono::duration<double,milli>(chrono::high_resolution_clock::now()-s).count();
        cout<<"\n  [Bubble Sort by Distance] "<<count<<" nodes in "<<fixed<<setprecision(4)<<lastSortTimeMs<<" ms\n";
        cout<<"  Time Complexity: O(n^2) | Space: O(1)\n";
    }
    void sortByEmission(){
        if(!head||!head->next)return;
        auto s=chrono::high_resolution_clock::now();bool sw;
        do{sw=false;Node*c=head;while(c->next){if(c->totalEmission>c->next->totalEmission){swapData(c,c->next);sw=true;}c=c->next;}}while(sw);
        lastSortTimeMs=chrono::duration<double,milli>(chrono::high_resolution_clock::now()-s).count();
        cout<<"\n  [Bubble Sort by Emission] "<<count<<" nodes in "<<fixed<<setprecision(4)<<lastSortTimeMs<<" ms\n";
        cout<<"  Time Complexity: O(n^2) | Space: O(1)\n";
    }
    void sortByResidentID(){
        if(!head||!head->next)return;
        auto s=chrono::high_resolution_clock::now();bool sw;
        do{sw=false;Node*c=head;while(c->next){if(c->residentID>c->next->residentID){swapData(c,c->next);sw=true;}c=c->next;}}while(sw);
        lastSortTimeMs=chrono::duration<double,milli>(chrono::high_resolution_clock::now()-s).count();
    }

    // ---- INSERTION SORT ----
    void insertionSortByAge(){
        if(!head||!head->next)return;
        auto s=chrono::high_resolution_clock::now();
        Node*sorted=nullptr,*cur=head;
        while(cur){Node*nxt=cur->next;
            if(!sorted||cur->age<=sorted->age){cur->next=sorted;sorted=cur;}
            else{Node*t=sorted;while(t->next&&t->next->age<cur->age)t=t->next;cur->next=t->next;t->next=cur;}
            cur=nxt;}
        head=sorted;
        lastSortTimeMs=chrono::duration<double,milli>(chrono::high_resolution_clock::now()-s).count();
        cout<<"\n  [Insertion Sort by Age] "<<count<<" nodes in "<<fixed<<setprecision(4)<<lastSortTimeMs<<" ms\n";
        cout<<"  Time Complexity: O(n^2) worst / O(n) best | Space: O(1)\n";
    }
    void insertionSortByDistance(){
        if(!head||!head->next)return;
        auto s=chrono::high_resolution_clock::now();
        Node*sorted=nullptr,*cur=head;
        while(cur){Node*nxt=cur->next;
            if(!sorted||cur->distance<=sorted->distance){cur->next=sorted;sorted=cur;}
            else{Node*t=sorted;while(t->next&&t->next->distance<cur->distance)t=t->next;cur->next=t->next;t->next=cur;}
            cur=nxt;}
        head=sorted;
        lastSortTimeMs=chrono::duration<double,milli>(chrono::high_resolution_clock::now()-s).count();
        cout<<"\n  [Insertion Sort by Distance] "<<count<<" nodes in "<<fixed<<setprecision(4)<<lastSortTimeMs<<" ms\n";
        cout<<"  Time Complexity: O(n^2) worst / O(n) best | Space: O(1)\n";
    }
    void insertionSortByEmission(){
        if(!head||!head->next)return;
        auto s=chrono::high_resolution_clock::now();
        Node*sorted=nullptr,*cur=head;
        while(cur){Node*nxt=cur->next;
            if(!sorted||cur->totalEmission<=sorted->totalEmission){cur->next=sorted;sorted=cur;}
            else{Node*t=sorted;while(t->next&&t->next->totalEmission<cur->totalEmission)t=t->next;cur->next=t->next;t->next=cur;}
            cur=nxt;}
        head=sorted;
        lastSortTimeMs=chrono::duration<double,milli>(chrono::high_resolution_clock::now()-s).count();
        cout<<"\n  [Insertion Sort by Emission] "<<count<<" nodes in "<<fixed<<setprecision(4)<<lastSortTimeMs<<" ms\n";
        cout<<"  Time Complexity: O(n^2) worst / O(n) best | Space: O(1)\n";
    }

    // ---- SEARCH ----
